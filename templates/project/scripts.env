# =============================================================================
# Project-specific script configuration
# Sourced by .ai/scripts/* at runtime
# =============================================================================

# Framework to use for test running.
# Must match a directory name under .ai/frameworks/ that contains run_tests.sh.
# Supported values: react-native, android
# Leave blank if this project uses a custom test runner.
FRAMEWORK="{{FRAMEWORK}}"

# Path to the directory containing the test config and package files,
# relative to the project root. Set to "." if they live at the root.
TEST_ROOT="{{TEST_ROOT}}"
